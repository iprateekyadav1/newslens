# Copy to .env and fill in values

# ── Model ─────────────────────────────────────────────────────
ROBERTA_BASE=roberta-base
# MODEL_PATH is auto-derived from models/newslens_best.pt

# ── Database ──────────────────────────────────────────────────
# Default: SQLite (development). Switch to PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/newslens
DATABASE_URL=sqlite:///./newslens.db

# ── API ───────────────────────────────────────────────────────
MAX_TEXT_LENGTH=10000
MAX_BATCH_SIZE=10
RATE_ANALYZE=30/minute
RATE_BATCH=5/minute
# Comma-separated list. Use * to allow all.
ALLOWED_ORIGINS=*

# ── Scraper ───────────────────────────────────────────────────
SCRAPER_TIMEOUT=15

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
